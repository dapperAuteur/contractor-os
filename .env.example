SUPABASE__POSTGRES_HOST=
SUPABASE__SUPABASE_JWT_SECRET=
SUPABASE__NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE__POSTGRES_PRISMA_URL=
SUPABASE__POSTGRES_PASSWORD=
SUPABASE__POSTGRES_DATABASE=
SUPABASE__SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE__NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE__NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE__SUPABASE_SERVICE_ROLE_KEY=
SUPABASE__POSTGRES_URL_NON_POOLING=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_LIFETIME_PRICE_ID=price_...
STRIPE_CONTRACTOR_MONTHLY_PRICE_ID=price_...
STRIPE_CONTRACTOR_ANNUAL_PRICE_ID=price_...
STRIPE_CONTRACTOR_LIFETIME_PRICE_ID=price_...
STRIPE_LISTER_MONTHLY_PRICE_ID=price_...
STRIPE_LISTER_ANNUAL_PRICE_ID=price_...

# CashApp — alternative payment for lifetime purchases
NEXT_PUBLIC_CASHAPP_TAG=$WorkWitUS
# LMS — Teacher payout routing
# Comma-separated emails whose courses pay directly to the platform Stripe account (no Connect fees)
PLATFORM_TEACHER_EMAILS=bam@awews.com

# Shopify — generates unique single-use shirt promo codes per lifetime member
# SHOPIFY_SHOP_DOMAIN: your store's .myshopify.com URL (e.g. awesomewebstore.myshopify.com)
# SHOPIFY_ADMIN_API_TOKEN: Settings → Apps → Develop apps → Admin API token (needs write_price_rules scope)
# SHOPIFY_PRICE_RULE_ID: ID from Shopify Admin URL when viewing the discount: /admin/discounts/{ID}
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=shpat_...
SHOPIFY_PRICE_RULE_ID=

# Resend — transactional email for admin messages
# Get API key at https://resend.com → API Keys
# RESEND_FROM_EMAIL must be a verified domain in Resend
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=admin@your-domain.com

# Admin dashboard access — only this email can visit /admin
ADMIN_EMAIL=your@email.com
# Same value as ADMIN_EMAIL — needed client-side to bypass paywall for admin
NEXT_PUBLIC_ADMIN_EMAIL=your@email.com

# Public site URL (used in Stripe redirect URLs and email links)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Umami Analytics (optional — privacy-first page & event tracking)
# Get these from your Umami dashboard: Settings → Websites → your site
# Self-hosted: set all three. UMAMI_HOST_URL enables the ad-blocker proxy (server-side only).
# Cloud: set only WEBSITE_ID. Leave SCRIPT_URL and HOST_URL blank.
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_SCRIPT_URL=
UMAMI_HOST_URL=

# Switchy.io — tracked short links for blog, courses, and feature pages
# Get API token: Switchy dashboard → Settings → Integrations → API token
SWITCHY_API_TOKEN=
SWITCHY_DOMAIN=i.work.witus.online
# Comma-separated Switchy pixel UUIDs (Facebook, GA, TikTok, etc.)
# Find pixel IDs: Switchy dashboard → Settings → Pixels → copy UUID for each
SWITCHY_PIXEL_IDS=
